# =============================================
# DEÜ E-Posta Yönetim Sistemi - Environment Variables
# =============================================
# Production deployment için bu dosyayı .env olarak kopyalayın
# ve değerleri production ayarlarınıza göre güncelleyin
#
# UYARI: .env dosyası GIT'e commit edilmemelidir!
# =============================================

# ============= APPLICATION =============
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5118

# ============= DATABASE =============
# Ana Oracle Database (19c)
EPOSTA_DB_CONNECTION=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=172.22.2.101)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORA19C)));User Id=XXEPOSTA;Password=MF4A_POSTA;Min Pool Size=5;Max Pool Size=100;Connection Timeout=30;

# Oracle 11g Database (Personel verileri için - opsiyonel)
ORACLE11G_CONNECTION=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=deudbmc-scan.isx.deu.edu.tr)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=RACDEU)));User Id=XXPER;Password=NU_45ALBI;Min Pool Size=2;Max Pool Size=50;Connection Timeout=30;

# ============= JWT AUTHENTICATION =============
# UYARI: Production'da mutlaka değiştirin! Minimum 32 karakter olmalı
JWT_SECRET_KEY=Y7sN3qP9uR4xV1tA6bD8kL0zM2eH5wC9rG1jT3nF6vB8yX2pZ4aS7dQ0mE5cR9_DeuEpostaSystem
JWT_ISSUER=DeuEpostaSystem
JWT_AUDIENCE=DeuEpostaUsers
JWT_EXPIRATION_MINUTES=1440

# ============= LDAP SETTINGS =============
# DEÜ LDAP servisi için şifreleme anahtarı
LDAP_SERVICE_KEY=ndlar75aGaQ345a5s6s1a0?63dTTf
# RSA Public Key (XML formatında)
LDAP_RSA_PUBLIC_KEY=<RSAKeyValue><Modulus></Modulus><Exponent>AQAB</Exponent></RSAKeyValue>

# ============= EMAIL SETTINGS =============
SMTP_SERVER=giden.posta.deu.edu.tr
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=duyuru@deu.edu.tr
SMTP_FROM_NAME=DEÜ Email Sistemi
SMTP_USE_SSL=false
SMTP_USE_DEFAULT_CREDENTIALS=false

# ============= FILE SETTINGS =============
FILE_UPLOAD_PATH=uploads
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt

# ============= CORS SETTINGS =============
# Virgülle ayrılmış allowed origins listesi
CORS_ALLOWED_ORIGINS=https://kurumsalduyuru.deu.edu.tr

# ============= HANGFIRE =============
HANGFIRE_STORAGE_PATH=data/hangfire
HANGFIRE_DASHBOARD_ENABLED=true
HANGFIRE_DASHBOARD_REQUIRE_AUTH=true

# ============= LOGGING (SERILOG) =============
# Seq server (opsiyonel - merkezi log toplama)
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=jOPVMpFqA6bSVxS5AozE

# ============= SECURITY =============
ALLOWED_EMAIL_DOMAINS=deu.edu.tr
ENABLE_RATE_LIMIT=true
MAX_FILE_UPLOAD_SIZE_MB=50

# ============= HEALTH CHECKS =============
HEALTH_CHECK_ENABLED=true

# ============= PRODUCTION FLAGS =============
# Test modu (production'da false olmalı)
TEST_MODE_ENABLED=false
