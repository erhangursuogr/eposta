# =============================================
# DEÜ E-Posta Yönetim Sistemi - Environment Variables
# =============================================
# Production deployment için bu dosyayı .env olarak kopyalayın
# ve değerleri production ayarlarınıza göre güncelleyin
#
# UYARI: .env dosyası GIT'e commit edilmemelidir!
# =============================================

# ============= APPLICATION =============
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5118

# ============= DATABASE =============
# Ana Oracle Database (19c)
EPOSTA_DB_CONNECTION=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your-oracle-host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=your-service)));User Id=XXEPOSTA;Password=YOUR_STRONG_PASSWORD_HERE;Min Pool Size=5;Max Pool Size=100;Connection Timeout=30;

# Oracle 11g Database (Personel verileri için - opsiyonel)
ORACLE11G_CONNECTION=Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your-oracle-11g-host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=your-service)));User Id=XXPER;Password=YOUR_STRONG_PASSWORD_HERE;Min Pool Size=2;Max Pool Size=50;Connection Timeout=30;

# ============= JWT AUTHENTICATION =============
# UYARI: Production'da mutlaka değiştirin! Minimum 32 karakter olmalı
JWT_SECRET_KEY=YOUR_PRODUCTION_JWT_SECRET_KEY_MINIMUM_32_CHARACTERS_LONG_CHANGE_THIS
JWT_ISSUER=DeuEpostaSystem
JWT_AUDIENCE=DeuEpostaUsers
JWT_EXPIRATION_MINUTES=1440

# ============= LDAP SETTINGS =============
# DEÜ LDAP servisi için şifreleme anahtarı
LDAP_SERVICE_KEY=YOUR_LDAP_SERVICE_KEY_HERE
# RSA Public Key (XML formatında)
LDAP_RSA_PUBLIC_KEY=<RSAKeyValue>YOUR_RSA_PUBLIC_KEY_HERE</RSAKeyValue>

# ============= EMAIL SETTINGS =============
SMTP_SERVER=giden.posta.deu.edu.tr
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@deu.edu.tr
SMTP_FROM_NAME=DEÜ Email Sistemi
SMTP_USE_SSL=false
SMTP_USE_DEFAULT_CREDENTIALS=false

# ============= FILE SETTINGS =============
FILE_UPLOAD_PATH=/app/uploads
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt

# ============= CORS SETTINGS =============
# Virgülle ayrılmış allowed origins listesi
CORS_ALLOWED_ORIGINS=https://eposta.deu.edu.tr,https://eposta-test.deu.edu.tr

# ============= HANGFIRE =============
HANGFIRE_STORAGE_PATH=/app/data/hangfire
HANGFIRE_DASHBOARD_ENABLED=true
HANGFIRE_DASHBOARD_REQUIRE_AUTH=true

# ============= LOGGING (SERILOG) =============
# Seq server (opsiyonel - merkezi log toplama)
SEQ_SERVER_URL=http://seq-server:5341
SEQ_API_KEY=YOUR_SEQ_API_KEY_HERE

# ============= SECURITY =============
ALLOWED_EMAIL_DOMAINS=deu.edu.tr
ENABLE_RATE_LIMIT=true
MAX_FILE_UPLOAD_SIZE_MB=50

# ============= HEALTH CHECKS =============
HEALTH_CHECK_ENABLED=true

# ============= PRODUCTION FLAGS =============
# Test modu (production'da false olmalı)
TEST_MODE_ENABLED=false
